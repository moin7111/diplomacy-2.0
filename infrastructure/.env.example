# ============================================
# Diplomacy 2.0 - Environment Variables
# ============================================
# KOPIERE diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# --- Database (PostgreSQL) ---
POSTGRES_DB=diplomacy2
POSTGRES_USER=diplomacy2
POSTGRES_PASSWORD=DEIN_SICHERES_PASSWORT_HIER
DATABASE_URL=postgresql://diplomacy2:DEIN_SICHERES_PASSWORT_HIER@db:5432/diplomacy2

# --- Redis ---
REDIS_PASSWORD=DEIN_REDIS_PASSWORT_HIER
REDIS_URL=redis://:DEIN_REDIS_PASSWORT_HIER@redis:6379

# --- API ---
NODE_ENV=development
PORT=4000
JWT_SECRET=DEIN_JWT_SECRET_HIER_MINDESTENS_32_ZEICHEN
CORS_ORIGIN=*

# --- Server ---
SERVER_IP=91.99.192.76

# --- Ports (intern, nur localhost) ---
API_PORT=4000
DB_PORT=5433
REDIS_PORT=6379
