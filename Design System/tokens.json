{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Diplomacy 2.0 Design Tokens",
    "version": "1.0.0",
    "package": "D1 – Design System & Style Guide",
    "description": "Exportable Design Tokens for Figma, Tailwind CSS, React Native, and CSS Custom Properties"
  },

  "color": {
    "primary": {
      "navy": {
        "$value": "#1B2838",
        "$type": "color",
        "$description": "Haupthintergrund, Navigation, Karten-Overlay. Dunkelblau im Stil von WW1-Admiralskarten."
      },
      "navy-light": {
        "$value": "#253548",
        "$type": "color",
        "$description": "Aufgehellte Variante für Hover-States und Panel-Hintergründe."
      },
      "navy-dark": {
        "$value": "#111C27",
        "$type": "color",
        "$description": "Dunklere Variante für tiefe Schatten und Sidebar-Hintergründe."
      }
    },

    "secondary": {
      "bordeaux": {
        "$value": "#8B0000",
        "$type": "color",
        "$description": "Primary CTA-Buttons (Erstellen, Abgeben), Raketen-Icon. Tiefes Weinrot."
      },
      "bordeaux-light": {
        "$value": "#A50000",
        "$type": "color",
        "$description": "Hover-State für Bordeaux-Buttons."
      },
      "bordeaux-dark": {
        "$value": "#6B0000",
        "$type": "color",
        "$description": "Active/Pressed-State für Bordeaux-Buttons."
      }
    },

    "accent": {
      "gold": {
        "$value": "#C5A55A",
        "$type": "color",
        "$description": "Highlights, Ränge, VZ-Marker, Gold-Rahmen, Messing-Elemente."
      },
      "gold-light": {
        "$value": "#D4BA7A",
        "$type": "color",
        "$description": "Heller Gold-Ton für Glanz-Effekte und Icon-Rahmen."
      },
      "gold-dark": {
        "$value": "#9E7E3A",
        "$type": "color",
        "$description": "Dunkler Gold-Ton für Schatten auf Metallrahmen."
      },
      "gold-shine": {
        "$value": "#EDD898",
        "$type": "color",
        "$description": "Höchster Glanzpunkt auf Gold-Elementen (Spekularlicht)."
      }
    },

    "semantic": {
      "success": {
        "$value": "#2D5016",
        "$type": "color",
        "$description": "Buttons 'Beitreten', positive Aktionen, Einheiten-Zug erfolgreich."
      },
      "success-light": {
        "$value": "#3D6B20",
        "$type": "color",
        "$description": "Hover-State für Success-Buttons."
      },
      "warning": {
        "$value": "#D4A017",
        "$type": "color",
        "$description": "Timer-Warnung (letzte Minute), Resource-Alert."
      },
      "warning-bg": {
        "$value": "#2A1F05",
        "$type": "color",
        "$description": "Hintergrund für Warning-Toasts."
      },
      "danger": {
        "$value": "#CC0000",
        "$type": "color",
        "$description": "Angriffe, Zerstörung, Raketen-Einschlag, ungültige Züge (Blinken)."
      },
      "danger-light": {
        "$value": "#E60000",
        "$type": "color",
        "$description": "Blink-Animation bei ungültigem Zug."
      },
      "info": {
        "$value": "#2A6EA6",
        "$type": "color",
        "$description": "Info-Benachrichtigungen, neutrale System-Meldungen."
      }
    },

    "surface": {
      "paper": {
        "$value": "#F4E8C1",
        "$type": "color",
        "$description": "Pergament-Hintergrund für Panels, Scrolls, Vertrags-Overlays."
      },
      "paper-dark": {
        "$value": "#E8D5A0",
        "$type": "color",
        "$description": "Dunkleres Pergament für Trennlinien und Panel-Ränder."
      },
      "wood": {
        "$value": "#5C3A21",
        "$type": "color",
        "$description": "Holzrahmen der Karte, Panel-Borders, untere Navigationsleiste."
      },
      "wood-light": {
        "$value": "#7A4E2D",
        "$type": "color",
        "$description": "Helleres Holz für Highlights auf Rahmen."
      },
      "wood-dark": {
        "$value": "#3E2510",
        "$type": "color",
        "$description": "Dunkles Holz für Schatten und tiefe Kanten."
      },
      "overlay": {
        "$value": "rgba(27, 40, 56, 0.85)",
        "$type": "color",
        "$description": "Halbtransparentes Navy für Modals, Overlays, Fog-of-War."
      },
      "overlay-dark": {
        "$value": "rgba(17, 28, 39, 0.95)",
        "$type": "color",
        "$description": "Schweres Overlay für Hacker-Minute, Victory/Defeat Screen."
      }
    },

    "map": {
      "water": {
        "$value": "#4A7FA5",
        "$type": "color",
        "$description": "Meeresgebiete auf der Karte (Vintage-Blau)."
      },
      "water-deep": {
        "$value": "#2E5F80",
        "$type": "color",
        "$description": "Tieferes Wasser, Ozean-Schatten."
      },
      "land-neutral": {
        "$value": "#C8B887",
        "$type": "color",
        "$description": "Neutrales Landgebiet (nicht kontrolliert). Vintage Sandton."
      },
      "land-highlight": {
        "$value": "rgba(255, 220, 100, 0.35)",
        "$type": "color",
        "$description": "Hover-Glow auf Gebieten (halbtransparent Gelb)."
      },
      "land-selected": {
        "$value": "rgba(255, 255, 255, 0.25)",
        "$type": "color",
        "$description": "Ausgewähltes Gebiet (White Glow, Overlay)."
      },
      "supply-center": {
        "$value": "#C5A55A",
        "$type": "color",
        "$description": "Versorgungszentrum-Marker (Gold)."
      }
    },

    "nation": {
      "great-britain": {
        "$value": "#E8A0B0",
        "$type": "color",
        "$description": "Großbritannien – Rosa/Pink. Gebietsfärbung und Einheiten-Farbcodierung."
      },
      "german-reich": {
        "$value": "#4A4A4A",
        "$type": "color",
        "$description": "Deutsches Reich – Anthrazit/Schwarz."
      },
      "austria-hungary": {
        "$value": "#C0392B",
        "$type": "color",
        "$description": "Österreich-Ungarn – Rot."
      },
      "france": {
        "$value": "#3498DB",
        "$type": "color",
        "$description": "Frankreich – Blau."
      },
      "italy": {
        "$value": "#27AE60",
        "$type": "color",
        "$description": "Italien – Grün."
      },
      "russia": {
        "$value": "#F1C40F",
        "$type": "color",
        "$description": "Russland – Gelb."
      },
      "ottoman-empire": {
        "$value": "#1ABC9C",
        "$type": "color",
        "$description": "Osmanisches Reich – Türkis."
      }
    },

    "text": {
      "primary": {
        "$value": "#F4E8C1",
        "$type": "color",
        "$description": "Haupttext auf dunklem Hintergrund (Pergament-Ton)."
      },
      "secondary": {
        "$value": "#C5A55A",
        "$type": "color",
        "$description": "Sekundärtext, Labels, Gold-Akzente."
      },
      "muted": {
        "$value": "#8A9BAE",
        "$type": "color",
        "$description": "Inaktiver Text, Placeholder, Disabled-State."
      },
      "inverted": {
        "$value": "#1B2838",
        "$type": "color",
        "$description": "Text auf hellem Hintergrund (Pergament-Panels)."
      },
      "danger": {
        "$value": "#FF4444",
        "$type": "color",
        "$description": "Fehlermeldungen, ungültige Zug-Anzeigen."
      }
    },

    "border": {
      "gold": {
        "$value": "#C5A55A",
        "$type": "color",
        "$description": "Standard Rahmen für Cards, Panels, Icon-Borders."
      },
      "gold-subtle": {
        "$value": "rgba(197, 165, 90, 0.4)",
        "$type": "color",
        "$description": "Dezenter Gold-Rahmen für innere Trennlinien."
      },
      "wood": {
        "$value": "#5C3A21",
        "$type": "color",
        "$description": "Holzrahmen, Karten-Border."
      },
      "dark": {
        "$value": "#111C27",
        "$type": "color",
        "$description": "Dunkler Rahmen für Input-Felder auf hellem Hintergrund."
      }
    }
  },

  "typography": {
    "fontFamily": {
      "heading": {
        "$value": "'Cinzel', 'Playfair Display', 'Georgia', serif",
        "$type": "fontFamily",
        "$description": "Serifenschrift für alle Überschriften. Cinzel vermittelt antike, militärische Würde. Google Fonts: Cinzel (Regular 400, Bold 700). Fallback: Playfair Display."
      },
      "body": {
        "$value": "'Inter', 'Source Sans Pro', -apple-system, sans-serif",
        "$type": "fontFamily",
        "$description": "Sans-Serif für Body-Text, Labels, Daten, UI-Elemente. Inter (400, 500, 600, 700). Tabular-Figures für Zahlen."
      },
      "mono": {
        "$value": "'JetBrains Mono', 'Courier New', monospace",
        "$type": "fontFamily",
        "$description": "Monospace für Codes (Raumcodes), Debugging, Timer-Anzeige."
      }
    },
    "fontSize": {
      "xs": { "$value": "11px", "$type": "dimension", "$description": "Badges, Timestamps, Micro-Labels." },
      "sm": { "$value": "13px", "$type": "dimension", "$description": "Captions, Hilfstexte, sekundäre Labels." },
      "base": { "$value": "15px", "$type": "dimension", "$description": "Basis Body-Text, Listenpunkte." },
      "md": { "$value": "17px", "$type": "dimension", "$description": "Primärer Body-Text, Button-Labels." },
      "lg": { "$value": "20px", "$type": "dimension", "$description": "Sektion-Überschriften, Card-Titel." },
      "xl": { "$value": "24px", "$type": "dimension", "$description": "Screen-Überschriften, Modal-Titel." },
      "2xl": { "$value": "30px", "$type": "dimension", "$description": "Hero-Überschriften (Home Screen, Lobby)." },
      "3xl": { "$value": "38px", "$type": "dimension", "$description": "Splash Screen Logo, Spielername groß." },
      "4xl": { "$value": "48px", "$type": "dimension", "$description": "Sieg/Niederlage Screen, dramatische Überschriften." }
    },
    "fontWeight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight": { "$value": 1.2, "$type": "number", "$description": "Überschriften." },
      "snug": { "$value": 1.35, "$type": "number", "$description": "Subheadings, Buttons." },
      "normal": { "$value": 1.5, "$type": "number", "$description": "Body-Text." },
      "relaxed": { "$value": 1.65, "$type": "number", "$description": "Lesbarer Body (Vertragstext, Rules)." }
    },
    "letterSpacing": {
      "tight": { "$value": "-0.02em", "$type": "dimension", "$description": "Große Display-Schrift." },
      "normal": { "$value": "0em", "$type": "dimension" },
      "wide": { "$value": "0.05em", "$type": "dimension", "$description": "Uppercase Labels, Button-Text." },
      "wider": { "$value": "0.1em", "$type": "dimension", "$description": "Caps-Lock Überschriften im Militär-Stil." },
      "widest": { "$value": "0.2em", "$type": "dimension", "$description": "Dekorative Trennlinien-Beschriftungen." }
    }
  },

  "spacing": {
    "comment": "8px Grid System. Alle Werte sind Vielfache von 4px (Basis) oder 8px (Haupt-Grid).",
    "0": { "$value": "0px", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" }
  },

  "borderRadius": {
    "none": { "$value": "0px", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension", "$description": "Subtile Rundung für Inputs, kleine Tags." },
    "md": { "$value": "8px", "$type": "dimension", "$description": "Standard Cards, Buttons, Panels." },
    "lg": { "$value": "12px", "$type": "dimension", "$description": "Große Cards, Modals." },
    "xl": { "$value": "16px", "$type": "dimension", "$description": "Overlays, Hero-Bereiche." },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Pills, Badges, runde Icons." }
  },

  "borderWidth": {
    "thin": { "$value": "1px", "$type": "dimension" },
    "base": { "$value": "2px", "$type": "dimension", "$description": "Standard Card und Button Rahmen." },
    "thick": { "$value": "3px", "$type": "dimension", "$description": "Betonter Rahmen, aktive Auswahl." },
    "heavy": { "$value": "4px", "$type": "dimension", "$description": "Holzrahmen-Simulation, Karten-Rand." }
  },

  "shadow": {
    "sm": {
      "$value": "0 1px 3px rgba(0, 0, 0, 0.4)",
      "$type": "shadow",
      "$description": "Subtiler Schatten für inaktive Elemente."
    },
    "base": {
      "$value": "0 2px 8px rgba(0, 0, 0, 0.5)",
      "$type": "shadow",
      "$description": "Standard Schatten für Cards und Panels."
    },
    "md": {
      "$value": "0 4px 16px rgba(0, 0, 0, 0.6)",
      "$type": "shadow",
      "$description": "Erhobene Cards, aktive Elemente."
    },
    "lg": {
      "$value": "0 8px 32px rgba(0, 0, 0, 0.7)",
      "$type": "shadow",
      "$description": "Modals, Overlays, Floating Panels."
    },
    "gold-glow": {
      "$value": "0 0 12px rgba(197, 165, 90, 0.5), 0 0 4px rgba(197, 165, 90, 0.8)",
      "$type": "shadow",
      "$description": "Gold-Glow für aktive Icons, VZ-Marker, ausgewählte Einheiten."
    },
    "gold-glow-strong": {
      "$value": "0 0 24px rgba(197, 165, 90, 0.7), 0 0 8px rgba(197, 165, 90, 1.0)",
      "$type": "shadow",
      "$description": "Starker Gold-Glow für Hover/Focus auf wichtigen CTA-Elementen."
    },
    "danger-glow": {
      "$value": "0 0 12px rgba(204, 0, 0, 0.6), 0 0 4px rgba(204, 0, 0, 0.9)",
      "$type": "shadow",
      "$description": "Rot-Glow für Angriffe, ungültige Züge, Raketen-Einschlag."
    },
    "inset": {
      "$value": "inset 0 2px 6px rgba(0, 0, 0, 0.5)",
      "$type": "shadow",
      "$description": "Eingedrückter Schatten für aktive Buttons (Pressed-State)."
    },
    "button-raised": {
      "$value": "0 4px 0px rgba(0, 0, 0, 0.5), 0 2px 8px rgba(0, 0, 0, 0.4)",
      "$type": "shadow",
      "$description": "Erhöhter Button-Schatten (taktile Haptik-Simulation)."
    },
    "button-pressed": {
      "$value": "0 1px 0px rgba(0, 0, 0, 0.5), inset 0 2px 4px rgba(0, 0, 0, 0.4)",
      "$type": "shadow",
      "$description": "Gedrückter Button-Schatten (Active-State)."
    }
  },

  "animation": {
    "duration": {
      "instant": { "$value": "80ms", "$type": "duration", "$description": "Sofortiges Feedback (Tap-Response)." },
      "fast": { "$value": "150ms", "$type": "duration", "$description": "Micro-Interaktionen, Icon-Wechsel." },
      "base": { "$value": "250ms", "$type": "duration", "$description": "Standard UI-Übergänge." },
      "slow": { "$value": "400ms", "$type": "duration", "$description": "Panel-Slide-In, Modal-Open." },
      "dramatic": { "$value": "700ms", "$type": "duration", "$description": "Einheiten-Bewegung, Befehlsauflösung." },
      "epic": { "$value": "1200ms", "$type": "duration", "$description": "Raketen-Flugbahn, Sieg/Niederlage-Screen." }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Standard Material-ähnliche Kurve." },
      "in": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier", "$description": "Elemente, die sich entfernen." },
      "out": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Elemente, die hereinkommen." },
      "spring": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "Federnder Effekt für Einheiten-Bewegung und Pop-Ins." },
      "dramatic": { "$value": "cubic-bezier(0.22, 1, 0.36, 1)", "$type": "cubicBezier", "$description": "Dramatische Verlangsamung am Ende (Rakete, Sieg)." }
    }
  },

  "sizing": {
    "touch-target-min": { "$value": "44px", "$type": "dimension", "$description": "WCAG 2.1 AA – Minimum Touch-Target für alle interaktiven Elemente." },
    "icon-xs": { "$value": "16px", "$type": "dimension" },
    "icon-sm": { "$value": "20px", "$type": "dimension" },
    "icon-base": { "$value": "24px", "$type": "dimension" },
    "icon-lg": { "$value": "32px", "$type": "dimension" },
    "icon-xl": { "$value": "48px", "$type": "dimension" },
    "avatar-sm": { "$value": "40px", "$type": "dimension", "$description": "Spieler-Avatar in Listen." },
    "avatar-base": { "$value": "64px", "$type": "dimension", "$description": "Spieler-Avatar in Lobby." },
    "avatar-lg": { "$value": "120px", "$type": "dimension", "$description": "Spieler-Avatar auf Home Screen." },
    "avatar-hero": { "$value": "160px", "$type": "dimension", "$description": "Großes Avatar-Icon auf Home Screen (mit Glow-Ring)." },
    "nav-height": { "$value": "64px", "$type": "dimension", "$description": "Höhe der unteren Navigationsleiste (collapsed)." },
    "nav-height-expanded": { "$value": "280px", "$type": "dimension", "$description": "Höhe der unteren Navigationsleiste (expanded)." },
    "topbar-height": { "$value": "56px", "$type": "dimension", "$description": "Höhe der oberen Info-Leiste." }
  },

  "zIndex": {
    "base": { "$value": 0, "$type": "number" },
    "raised": { "$value": 10, "$type": "number", "$description": "Erhobene Cards, Tooltips." },
    "dropdown": { "$value": 100, "$type": "number", "$description": "Dropdown-Menus." },
    "sticky": { "$value": 200, "$type": "number", "$description": "Sticky Header, fixe Navigation." },
    "overlay": { "$value": 500, "$type": "number", "$description": "Modals, Overlays." },
    "hacker-minute": { "$value": 800, "$type": "number", "$description": "Hacker-Minute Vollbild-Overlay." },
    "toast": { "$value": 900, "$type": "number", "$description": "Toast-Nachrichten, Error-Feedback." },
    "max": { "$value": 9999, "$type": "number", "$description": "Sieg/Niederlage-Screen, kritische Overlays." }
  }
}
